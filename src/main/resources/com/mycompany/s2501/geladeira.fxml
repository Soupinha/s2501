<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.s2501.Cozinha.GeladeiraController">
    <children>
        <Label text="Secondary View" />
        <Button 
            prefHeight="15.0" 
            fx:id="secondaryButton" onAction="#switchToPrimary"
            prefWidth="15.0" 
            style="-fx-background-radius: 100em; -fx-min-width: 15px; -fx-min-height: 15px; -fx-max-width: 15px; -fx-max-height: 15px; -fx-padding: 0; -fx-background-color: #ffffff; " 
        />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="800.0"
            prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/13"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.s2501.RankingController"
            style="-fx-background-color: #171414;">

    <children>
        <TableView fx:id="tabelaRanking"
                   layoutX="150.0"
                   layoutY="100.0"
                   prefWidth="900.0"
                   prefHeight="500.0">

            <columns>
                <TableColumn fx:id="colJogatina" text="Jogatina" prefWidth="140.0" />
                <TableColumn fx:id="colPontos" text="Pontos" prefWidth="160.0" />
                <TableColumn fx:id="colRunsVencidas" text="Runs vencidas" prefWidth="170.0" />
                <TableColumn fx:id="colRunsPerdidas" text="Runs perdidas" prefWidth="170.0" />
                <TableColumn fx:id="colTempo" text="Tempo total" prefWidth="160.0" />
                <TableColumn fx:id="colFinal" text="Final" prefWidth="100.0" />
            </columns>
        </TableView>

        <Button layoutX="330.0"
                layoutY="650.0"
                prefWidth="150.0"
                prefHeight="40.0"
                text="Exportar CSV"
                onAction="#exportarCSV" />

        <Button layoutX="525.0"
                layoutY="650.0"
                prefWidth="150.0"
                prefHeight="40.0"
                text="Exportar TXT"
                onAction="#exportarTXT" />

        <Button layoutX="720.0"
                layoutY="650.0"
                prefWidth="150.0"
                prefHeight="40.0"
                text="Voltar"
                onAction="#voltar" />
    </children>
</AnchorPane>
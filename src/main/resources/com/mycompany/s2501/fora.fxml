<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" 
            style="-fx-background-image: url('/com/mycompany/s2501/jogotlp/fora1.png');        -fx-background-size: cover;        -fx-background-repeat: no-repeat;" 
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mycompany.s2501.Fora.ForaController">

    <children>
        <Label layoutX="550.0" layoutY="100.0" text="" />
        
        <Button layoutX="1140.0" 
                layoutY="20.0" 
                onAction="#abrirInventario" 
                text="🎒" />

        <Button fx:id="irua2" 
                layoutX="1080.0" 
                layoutY="420.0"
                onAction="#irrua2" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ir para a direita" />
            </tooltip>
        </Button>
        
        <Button fx:id="irua1" 
                layoutX="120.0" 
                layoutY="420.0" 
                onAction="#irrua1" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ir para a esquerda" />
            </tooltip>
        </Button>
        
        <Button fx:id="irpraca"  
                layoutX="600.0" 
                layoutY="480.0" 
                onAction="#irpraca" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ir para a praça" />
            </tooltip>
        </Button>
        
        <Button fx:id="voltar" 
                layoutX="600.0" 
                layoutY="780.0" 
                onAction="#voltar" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Voltar para a casa" />
            </tooltip>
        </Button>
        
        
        
        
        
    </children>
</AnchorPane>
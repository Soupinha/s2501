<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            style="-fx-background-image: url('/com/mycompany/s2501/loja/loja1.png'); -fx-background-size: cover; -fx-background-repeat: no-repeat;"
            xmlns="http://javafx.com/javafx/13"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.s2501.Cozinha.LojaController">

    <children>

      

        <AnchorPane fx:id="remedio1Box"
                layoutX="175.0" layoutY="125.0"
                prefHeight="105.0" prefWidth="105.0"
                onMouseEntered="#mostrarRemedio1"
                pickOnBounds="true">
            <children>
                <ImageView fitHeight="105.0" fitWidth="105.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@loja/remedio1.png" />
                    </image>
                </ImageView>
            </children>
        </AnchorPane>

        <AnchorPane fx:id="remedio2Box"
                    layoutX="307.0" layoutY="115.0"
                    prefHeight="105.0" prefWidth="105.0"
                    onMouseEntered="#mostrarRemedio2"
                    pickOnBounds="true">
            <children>
                <ImageView fitHeight="105.0" fitWidth="105.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@loja/remedio2.png" />
                    </image>
                </ImageView>
            </children>
        </AnchorPane>

        <AnchorPane fx:id="remedio3Box"
                    layoutX="175.0" layoutY="226.0"
                    prefHeight="105.0" prefWidth="105.0"
                    onMouseEntered="#mostrarRemedio3"
                    pickOnBounds="true">
            <children>
                <ImageView fitHeight="105.0" fitWidth="105.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@loja/remedio3.png" />
                    </image>
                </ImageView>
                <Label layoutX="8.0"
                       layoutY="38.0"
                       prefWidth="88.0"
                       prefHeight="24.0"
                       alignment="CENTER"
                       text="ESGOTADO"
                       style="-fx-background-color: rgba(0,0,0,0.78);
                              -fx-text-fill: #d8d8d8;
                              -fx-font-size: 12px;
                              -fx-font-weight: bold;" />
            </children>
        </AnchorPane>

        <AnchorPane fx:id="remedio4Box"
                    layoutX="307.0" layoutY="226.0"
                    prefHeight="105.0" prefWidth="105.0"
                    onMouseEntered="#mostrarRemedio4"
                    pickOnBounds="true">
            <children>
                <ImageView fitHeight="105.0" fitWidth="105.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@loja/remedio4.png" />
                    </image>
                </ImageView>
            </children>
        </AnchorPane>

       <Label fx:id="mensagemLoja"
            layoutX="110.0" layoutY="340.0"
            prefHeight="30.0" prefWidth="380.0"
            alignment="CENTER"
            text="Clique em um remédio para conferir."
            style="-fx-background-color: rgba(0, 0, 0, 0.55); -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 5px; -fx-background-radius: 8px;" />
       
            <AnchorPane fx:id="painelInfoRemedio"
                layoutX="410.0"
                layoutY="70.0"
                prefWidth="170.0"
                prefHeight="300.0"
                visible="false"
                style="-fx-background-color: rgba(0, 0, 0, 0.70);
                       -fx-background-radius: 10px;
                       -fx-padding: 10px;">

        <children>
            <Label fx:id="nomeRemedioLabel"
                   layoutX="10.0"
                   layoutY="10.0"
                   prefWidth="150.0"
                   prefHeight="25.0"
                   text="Nome"
                   style="-fx-text-fill: white;
                          -fx-font-size: 15px;
                          -fx-font-weight: bold;" />

            <Label fx:id="descricaoRemedioLabel"
                   layoutX="10.0"
                   layoutY="45.0"
                   prefWidth="150.0"
                   prefHeight="90.0"
                   wrapText="true"
                   text="Descrição"
                   style="-fx-text-fill: white;
                          -fx-font-size: 11px;" />

            <Label fx:id="precoRemedioLabel"
                   layoutX="10.0"
                   layoutY="145.0"
                   prefWidth="150.0"
                   prefHeight="25.0"
                   text="Preço: 0 moedas"
                   style="-fx-text-fill: white;
                          -fx-font-size: 12px;" />

            <Label fx:id="quantidadeRemedioLabel"
                   layoutX="10.0"
                   layoutY="175.0"
                   prefWidth="150.0"
                   prefHeight="55.0"
                   text="Disponível: 3"
                   style="-fx-text-fill: white;
                          -fx-font-size: 12px;" />

            <Button fx:id="comprarButton"
                    layoutX="35.0"
                    layoutY="245.0"
                    prefWidth="100.0"
                    prefHeight="28.0"
                    text="Comprar"
                    onAction="#comprarSelecionado" />
        </children>
    </AnchorPane>
        
        <AnchorPane fx:id="moedasBox"
            layoutX="465.0"
            layoutY="15.0"
            prefWidth="115.0"
            prefHeight="30.0"
            style="-fx-background-color: rgba(0, 0, 0, 0.65);
                   -fx-background-radius: 10px;">

            <children>
                <Label fx:id="moedasLabel"
                       layoutX="10.0"
                       layoutY="5.0"
                       prefWidth="95.0"
                       prefHeight="20.0"
                       text="Moedas: 0"
                       alignment="CENTER"
                       style="-fx-text-fill: white;
                              -fx-font-size: 12px;
                              -fx-font-weight: bold;" />
            </children>
        </AnchorPane>

    </children>
</AnchorPane>

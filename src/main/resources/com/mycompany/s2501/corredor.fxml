<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-image: url('/com/mycompany/s2501/corredor1.png');        -fx-background-size: cover;        -fx-background-repeat: no-repeat;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.s2501.Corredor.CorredorController">

    <children>
        <Label layoutX="550.0" layoutY="100.0" text="" />
        
        <Button layoutX="1140.0" 
                layoutY="20.0" 
                onAction="#abrirInventario" 
                text="🎒" />

        <Button fx:id="portaquartot" 
                layoutX="820.0" 
                layoutY="430.0"
                onAction="#irquartot" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ir para o segundo quarto" />
            </tooltip>
        </Button>
        
        <Button fx:id="portabanheiro" 
                layoutX="340.0" 
                layoutY="440.0" 
                onAction="#irbanheiro" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ir para o banheiro" />
            </tooltip>
        </Button>
        
        <Button fx:id="descada"  
                layoutX="650.0" 
                layoutY="490.0" 
                onAction="#descerescada" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Descer as escadas" />
            </tooltip>
        </Button>
        
        <Button fx:id="voltarquarto" 
                layoutX="600.0" 
                layoutY="780.0" 
                onAction="#voltarquarto" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Voltar para o quarto" />
            </tooltip>
        </Button>
        
        
        
        
        
    </children>
</AnchorPane>
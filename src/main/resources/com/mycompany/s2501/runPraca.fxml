<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="root"
            prefWidth="1200.0"
            prefHeight="400.0"
            focusTraversable="true"
            xmlns="http://javafx.com/javafx/13"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.s2501.Runs.RunPracaController">

    <children>

        <ImageView fx:id="background"
                   fitWidth="1200.0"
                   fitHeight="400.0"
                   preserveRatio="false" />

        <ImageView fx:id="player"
           fitWidth="160.0"
           fitHeight="220.0"
           preserveRatio="true"
           layoutX="520.0"
           layoutY="170.0" />

        <AnchorPane fx:id="npcLayer"
                    prefWidth="1200.0"
                    prefHeight="400.0"
                    pickOnBounds="false" />

        <Label fx:id="tempoLabel"
               layoutX="20.0"
               layoutY="20.0"
               prefWidth="160.0"
               prefHeight="30.0"
               text="Tempo: 90"
               style="-fx-background-color: rgba(0,0,0,0.55);
                      -fx-text-fill: white;
                      -fx-font-size: 16px;
                      -fx-padding: 5px;
                      -fx-background-radius: 8px;" />

        <AnchorPane fx:id="painelInicio"
                    prefWidth="1200.0"
                    prefHeight="400.0"
                    style="-fx-background-color: rgba(0,0,0,0.78);">

            <children>
                <Label layoutX="300.0"
                       layoutY="80.0"
                       prefWidth="600.0"
                       prefHeight="160.0"
                       alignment="CENTER"
                       wrapText="true"
                       text="Run Praça&#10;&#10;Use A/D ou ←/→ para andar.&#10;Use E para interagir.&#10;&#10;Dica: é muito melhor ter uma companhia para descansar."
                       style="-fx-text-fill: white;
                              -fx-font-size: 22px;
                              -fx-font-weight: bold;" />

                <Button layoutX="520.0"
                        layoutY="280.0"
                        prefWidth="160.0"
                        prefHeight="40.0"
                        text="Começar"
                        onAction="#iniciarJogo" />
            </children>
        </AnchorPane>

        <AnchorPane fx:id="painelFinal"
                    prefWidth="1200.0"
                    prefHeight="400.0"
                    visible="false"
                    style="-fx-background-color: rgba(0,0,0,0.85);">

            <children>
                <Label fx:id="mensagemFinalLabel"
                       layoutX="300.0"
                       layoutY="140.0"
                       prefWidth="600.0"
                       prefHeight="120.0"
                       alignment="CENTER"
                       wrapText="true"
                       text=""
                       style="-fx-text-fill: white;
                              -fx-font-size: 24px;
                              -fx-font-weight: bold;" />
            </children>
        </AnchorPane>

    </children>
</AnchorPane>
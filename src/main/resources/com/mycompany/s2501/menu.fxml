<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="800.0"
            prefWidth="1200.0"
            style="-fx-background-image: url('/com/mycompany/s2501/jogotlp/menu1.png');
                   -fx-background-size: cover;
                   -fx-background-repeat: no-repeat;"
            xmlns="http://javafx.com/javafx/13"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.s2501.MenuController">

    <children>

        <Button fx:id="jogar"
                layoutX="520.0"
                layoutY="480.0"
                onAction="#comecar"
                prefHeight="42.0"
                prefWidth="170.0"
                text="JOGAR"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #d7d2c8;
                       -fx-border-color: #6e6558;
                       -fx-border-width: 0 0 1.5 0;
                       -fx-font-family: 'Times New Roman';
                       -fx-font-size: 20px;
                       -fx-cursor: hand;" />

        <Button fx:id="creditos"
                layoutX="520.0"
                layoutY="530.0"
                onAction="#abrirCreditos"
                prefHeight="42.0"
                prefWidth="170.0"
                text="CRÉDITOS"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #d7d2c8;
                       -fx-border-color: #6e6558;
                       -fx-border-width: 0 0 1.5 0;
                       -fx-font-family: 'Times New Roman';
                       -fx-font-size: 20px;
                       -fx-cursor: hand;" />

        <Button fx:id="ranking"
                layoutX="520.0"
                layoutY="580.0"
                onAction="#abrirRanking"
                prefHeight="42.0"
                prefWidth="170.0"
                text="RANKING"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #d7d2c8;
                       -fx-border-color: #6e6558;
                       -fx-border-width: 0 0 1.5 0;
                       -fx-font-family: 'Times New Roman';
                       -fx-font-size: 20px;
                       -fx-cursor: hand;" />

        <Button fx:id="encerrar"
                layoutX="520.0"
                layoutY="630.0"
                onAction="#encerrarJogo"
                prefHeight="42.0"
                prefWidth="170.0"
                text="ENCERRAR"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #d7d2c8;
                       -fx-border-color: #6e6558;
                       -fx-border-width: 0 0 1.5 0;
                       -fx-font-family: 'Times New Roman';
                       -fx-font-size: 20px;
                       -fx-cursor: hand;" />

        <AnchorPane fx:id="painelCreditos"
                    prefHeight="800.0"
                    prefWidth="1200.0"
                    visible="false"
                    style="-fx-background-color: rgba(0, 0, 0, 0.60);">

            <children>
                <AnchorPane layoutX="250.0"
                            layoutY="130.0"
                            prefHeight="500.0"
                            prefWidth="700.0"
                            style="-fx-background-color: rgba(20, 18, 18, 0.90);
                                   -fx-border-color: #8c7f6d;
                                   -fx-border-width: 2;
                                   -fx-background-radius: 10;
                                   -fx-border-radius: 10;">

                    <children>
                        <Label layoutX="260.0"
                               layoutY="35.0"
                               text="CRÉDITOS"
                               style="-fx-text-fill: #e8e2d7;
                                      -fx-font-family: 'Times New Roman';
                                      -fx-font-size: 30px;
                                      -fx-font-weight: bold;" />

                        <Label layoutX="110.0"
                               layoutY="115.0"
                               prefWidth="500.0"
                               text="Sophia dos Santos Soares"
                               style="-fx-text-fill: #d7d2c8;
                                      -fx-font-family: 'Times New Roman';
                                      -fx-font-size: 25px;
                                      -fx-font-weight: bold;" />

                        <Label layoutX="110.0"
                               layoutY="180.0"
                               text="Disciplina:"
                               style="-fx-text-fill: #b9b1a3;
                                      -fx-font-family: 'Times New Roman';
                                      -fx-font-size: 20px;
                                      -fx-font-weight: bold;" />

                        <Label layoutX="110.0"
                               layoutY="215.0"
                               prefWidth="540.0"
                               text="Tópicos em Linguagem de Programação 2"
                               style="-fx-text-fill: #d7d2c8;
                                      -fx-font-family: 'Times New Roman';
                                      -fx-font-size: 22px;" />

                        <Label layoutX="110.0"
                               layoutY="290.0"
                               text="Tecnologias utilizadas:"
                               style="-fx-text-fill: #b9b1a3;
                                      -fx-font-family: 'Times New Roman';
                                      -fx-font-size: 20px;
                                      -fx-font-weight: bold;" />

                        <Label layoutX="110.0"
                               layoutY="330.0"
                               prefWidth="350.0"
                               prefHeight="120.0"
                               text="• pgAdmin&#10;• NetBeans&#10;• GitHub&#10;• ChatGPT"
                               style="-fx-text-fill: #d7d2c8;
                                      -fx-font-family: 'Times New Roman';
                                      -fx-font-size: 22px;" />

                        <Button layoutX="280.0"
                                layoutY="430.0"
                                onAction="#fecharCreditos"
                                prefHeight="38.0"
                                prefWidth="140.0"
                                text="VOLTAR"
                                style="-fx-background-color: #2c2725;
                                       -fx-text-fill: #e8e2d7;
                                       -fx-border-color: #8c7f6d;
                                       -fx-border-width: 1.5;
                                       -fx-font-family: 'Times New Roman';
                                       -fx-font-size: 18px;
                                       -fx-cursor: hand;" />
                    </children>
                </AnchorPane>
            </children>
        </AnchorPane>

        <AnchorPane fx:id="fadePane"
                    prefHeight="800.0"
                    prefWidth="1200.0"
                    visible="false"
                    opacity="0.0"
                    mouseTransparent="true"
                    style="-fx-background-color: black;" />

    </children>
</AnchorPane>
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Abrir o armario" />
            </tooltip>
        </Button>
        
        <Button fx:id="voltarcorredorp" 
                layoutX="600.0" 
                layoutY="780.0" 
                onAction="#voltarcorredorp" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Voltar ao corredor principal" />
            </tooltip>
        </Button>
        
        
        
        
        
    </children>
</AnchorPane>
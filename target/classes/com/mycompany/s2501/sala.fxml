<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-image: url('/com/mycompany/s2501/sala2.png');        -fx-background-size: cover;        -fx-background-repeat: no-repeat;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.s2501.Sala.SalaController">

    <children>
        <Label layoutX="550.0" layoutY="100.0" text="" />
        
        <Button layoutX="1140.0" 
                layoutY="20.0" 
                onAction="#abrirInventario" 
                text="🎒" />

        <Button fx:id="verfoto" 
                layoutX="1120.0" 
                layoutY="410.0"
                onAction="#verfoto" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ver retrato" />
            </tooltip>
        </Button>
        
        <Button fx:id="verjanela" 
                layoutX="370.0" 
                layoutY="400.0" 
                onAction="#verjanela" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ver a janela" />
            </tooltip>
        </Button>
        
        <Button fx:id="sentarsofa" 
                layoutX="100.0" 
                layoutY="440.0" 
                onAction="#sentarsofa" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Sentar no sofá" />
            </tooltip>
        </Button>
        
        <Button fx:id="abrirarmario"  
                layoutX="760.0" 
                layoutY="455.0" 
                onAction="#abrirarmario"
                prefHeight="15.0" 
                prefWidth="15.0" 

                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ver retrato" />
            </tooltip>
        </Button>
        
        <Button fx:id="janela" 

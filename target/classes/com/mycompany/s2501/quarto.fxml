<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" 
            style="-fx-background-image: url('/com/mycompany/s2501/jogotlp/quarto2.png');        -fx-background-size: cover;        -fx-background-repeat: no-repeat;" 
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mycompany.s2501.Quarto.QuartoController">
            <!--Tudo okay-->
    <children>
        <Label layoutX="550.0" layoutY="100.0" text="" />
        
        <Button layoutX="1140.0" 
                layoutY="20.0" 
                onAction="#abrirInventario" 
                text="🎒" />

        <Button fx:id="criado" 
                layoutX="505.0" 
                layoutY="410.0" 
                onAction="#ircriado"
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ver o criado-mudo" />
            </tooltip>
        </Button>
        
        <Button fx:id="portaquarto" 
                layoutX="680.0" 
                layoutY="300.0" 
                onAction="#ircorredor" 
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ir para o corredor" />
            </tooltip>
        </Button>
        
        <Button fx:id="armario" 
                layoutX="910.0" 
                layoutY="340.0" 
                onAction="#irarmario"
                prefHeight="15.0" 
                prefWidth="15.0" 
                style="-fx-background-radius: 100em;                    
                        -fx-min-width: 15px;                    
                        -fx-min-height: 15px;                    
                        -fx-max-width: 15px;                    
                        -fx-max-height: 15px;                    
                        -fx-padding: 0;                    
                        -fx-background-color: #ffffff;">

            <tooltip>
                <Tooltip text="Ver o armário" />
            </tooltip>
        </Button>
        
       <Label fx:id="floatingText"
       layoutX="350"
       layoutY="680"
       text=""
       prefWidth="500"
       wrapText="true"
       alignment="CENTER"
       style="-fx-text-fill: white;
              -fx-font-size: 28;
              -fx-background-color: rgba(0,0,0,0.2);" />
        
        <Button fx:id="botaoContinuar"
        text="Continuar"
        layoutX="540"
        layoutY="720"
        onAction="#proximaFrase"
        style="-fx-background-color: transparent;
               -fx-text-fill: #d7d2c8;
               -fx-border-color: #6e6558;
               -fx-border-width: 0 0 1.5 0;
               -fx-font-family: 'Times New Roman';
               -fx-font-size: 20px;
               -fx-cursor: hand;" 
        />
        
    </children>
</AnchorPane>